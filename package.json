{
  "name": "fastify-trident",
  "version": "0.2.1",
  "description": "one-file, one-endpoint.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmaseCocoa/trident.git"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "bugs": {
    "url": "https://github.com/AmaseCocoa/trident/issues"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run publint && npm run build",
    "publint": "tsdown --publint"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "bullmq": "^5.77.6",
    "fastify": "^5.8.5",
    "glob": "^13.0.6",
    "ioredis": "^5.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "publint": "^0.3.21",
    "tsdown": "^0.22.1",
    "tsup": "^8.5.1"
  }
}
