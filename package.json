{
  "name": "fastify-trident",
  "version": "0.2.1",
  "description": "one-file, one-endpoint.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmaseCocoa/trident"
  },
  "bugs": {
    "url": "https://github.com/AmaseCocoa/trident/issues"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "bullmq": "^5.77.6",
    "fastify": "^5.8.5",
    "glob": "^13.0.6",
    "ioredis": "^5.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.1",
    "tsup": "^8.5.1"
  }
}
